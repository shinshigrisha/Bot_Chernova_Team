# Core
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789,987654321]
TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/delivery_assistant
# Для запуска scripts/smoke_ai.py на хосте (compose поднят): SMOKE_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/delivery_assistant
# DATABASE_SSL=true — для облачной БД с SSL; false (по умолчанию) — локальный postgres, не читать PGSSLMODE из env

# Analytics DB (read-only, для интеграции с Superset/Grafana и отчётов бота)
# См. docs/ANALYTICS_INTEGRATION_SPEC.md
# ANALYTICS_DATABASE_URL=postgresql://bot_reader:***@analytics-db:5432/analytics?sslmode=require
# или по частям:
# ANALYTICS_DB_HOST=analytics-db.internal
# ANALYTICS_DB_PORT=5432
# ANALYTICS_DB_NAME=analytics
# ANALYTICS_DB_SCHEMA=delivery
# ANALYTICS_DB_USER=bot_reader
# ANALYTICS_DB_PASSWORD=
# ANALYTICS_DB_SSL=true

# Redis
REDIS_URL=redis://redis:6379/0

# Celery (broker and result backend)
CELERY_BROKER_URL=redis://redis:6379/1

# Storage (MinIO/S3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=delivery-assistant

## ===== OpenAI-compatible endpoint =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.aiguoguo199.com/v1

# ===== Default AI routing =====
AI_DEFAULT_PROVIDER=openai_compatible
AI_DEFAULT_MODEL=gpt-5-mini

# ===== Fast chat for courier dialogs =====
AI_FAST_PROVIDER=openai_compatible
AI_FAST_MODEL=gpt-5-mini

# ===== Strong reasoning for ambiguous / complex cases =====
AI_REASONING_PROVIDER=openai_compatible
AI_REASONING_MODEL=gpt-5-chat-latest

# ===== Analytics / long reports / CSV analysis =====
AI_ANALYTICS_PROVIDER=openai_compatible
AI_ANALYTICS_MODEL=gpt-5-chat-latest

# ===== Cheap fallback =====
AI_FALLBACK_PROVIDER=openai_compatible
AI_FALLBACK_MODEL=gpt-5-nano

# ===== Embeddings (local MiniLM — внешний API не нужен; см. README § Установка локальных эмбеддингов MiniLM) =====
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== Budget protection =====
AI_MAX_OUTPUT_TOKENS=220
AI_MAX_CONTEXT_ITEMS=3
AI_ENABLE_HEAVY_ANALYTICS=false
AI_ENABLE_ANALYTICS_ASSISTANT=true
AI_ENABLE_RAG=true
AI_ENABLE_SEMANTIC_SEARCH=true
# n8n pilot: verification mirror (optional)
#N8N_VERIFICATION_MIRROR_ENABLED=true
#N8N_VERIFICATION_WEBHOOK_URL=https://your-n8n.example.com/webhook/verification-pending

# Automation webhook: POST /automation/event (0 = disabled)
# AUTOMATION_HTTP_PORT=8080

# Feature flags (поэтапное включение, по умолчанию false)
# ENABLE_MENU_V2=false
# ENABLE_VERIFICATION_NOTIFICATIONS=false
# ENABLE_ADMIN_MENU_V2=false
# ENABLE_AI_CHAT_V2=false
# ENABLE_FAQ_SEMANTIC_SEARCH=false
# ENABLE_RAG_ASSISTANT=false
