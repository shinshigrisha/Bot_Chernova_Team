# Core
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=[123456789,987654321]
TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/delivery_assistant
# DATABASE_SSL=true — для облачной БД с SSL; false (по умолчанию) — локальный postgres, не читать PGSSLMODE из env

# Redis
REDIS_URL=redis://redis:6379/0

# Celery (broker and result backend)
CELERY_BROKER_URL=redis://redis:6379/1

# Storage (MinIO/S3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=delivery-assistant

# AI (optional)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
AI_ENABLED=false
AI_PROVIDER_ORDER_CHAT=groq,deepseek,openai
AI_PROVIDER_ORDER_REASON=openai,deepseek,groq
