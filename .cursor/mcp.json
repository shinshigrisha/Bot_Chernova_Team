{
   "mcpServers": {
      "context7": {
         "command": "npx",
         "args": [
            "-y",
            "@upstash/context7-mcp"
         ],
         "env": {
            "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
         }
      },
      "task-master-ai": {
         "command": "npx",
         "args": [
            "-y",
            "--package=task-master-ai",
            "task-master-ai"
         ],
         "timeout": 300,
         "env": {
            "TASK_MASTER_TOOLS": "core"
         }
      }
   }
}